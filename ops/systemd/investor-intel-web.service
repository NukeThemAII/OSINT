[Unit]
Description=Investor Intel Web
After=network.target investor-intel-api.service

[Service]
Type=simple
WorkingDirectory=/opt/investor-intel
EnvironmentFile=/etc/investor-intel/investor-intel.env
ExecStart=/usr/bin/npm run start:web
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
